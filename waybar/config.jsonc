        "exec": "curl https://api.mcstatus.io/v2/status/java/mc.talbotnz.synology.me | jq -r --unbuffered --compact-output '.players | {\"text\": .online, \"tooltip\": [.list .[].name_clean] | join(\"\n\")}'",
        // This should refresh the player count on click
        "on-click": "",
        "return-type": "json",
        "interval": 480,
        "format": "у°ҶҰ {}"
    },
    "custom/updates": {
        // OH GOD WHAT HAVE I CREATED
        // and why does it not work????
        //"exec": "echo -n \"$((checkupdates ; yay -Qua) | tr '\n' '\"')\" | jq -Rr '{ \"updates\": . | split(\"\\\"\") | del(.[-1]) } | { \"text\": .updates | length, \"tooltip\": .updates }'",
        //"return-type": "json",
        "exec": "(checkupdates ; yay -Qua) | wc -l",
        "interval": 7200,
        "format": "пӣҷ {} "
    },*/
    "tray": {
        "icon-size": 13,
        "spacing": 10
    },
    "clock": {
        "format": "пҖ— {:%I:%M %p  пҒі %d/%m}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "wireplumber": {
        "format": "{icon} {volume}%",
        "tooltip": true,
        "format-muted": "пҖҰ Muted",
        "on-click": "pamixer --get-default-sink -t",	
        "on-scroll-up": "pamixer --get-default-sink -i 5",
        "on-scroll-down": "pamixer --get-default-sink -d 5",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "пҖҘ",
            "hands-free": "пҖҘ",
            "headset": "пҖҘ",
            "phone": "пӮ•",
            "portable": "пӮ•",
            "car": "пҶ№",
            "default": ["пҖҰ", "пҖ§", "пҖЁ"]
        }
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "пЎ« {volume}%",
        "format-source-muted": "пЎ¬ Muted",
        "on-click": "pamixer --default-source -t",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },
    "battery": {
        "bat": "BAT0",
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% п—§",
        "format-plugged": "{capacity}% пҮҰ",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["п–Қ", "п•№", "п•ә", "п•»", "п•ј", "п•Ҫ", "п•ҫ", "п•ҝ", "п–Җ", "п–Ғ", "п•ё"]
    },
    "network": {
        // "interface": "wlp*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) пҮ«",
        "format-ethernet": "{ipaddr}/{cidr} оҪ„",
        "tooltip-format": "{ifname} via {gwaddr} оҪ„",
        "format-linked": "{ifname} (No IP) пһ–",
        "format-disconnected": "Disconnected вҡ ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "cpu": {
        "interval": 10,
        "format": "пҳҰ {}%",
        "max-length": 10,
        "on-click": ""
    },
    "memory": {
        "interval": 15,
        "format":"п‘І {used:0.1f}G",
        "format-alt": "пҳӘ {}%",
        "max-length": 10
    },
    "backlight": {
        "format": "у°–Ё {}%",
        "on-scroll-up": "brightnessctl s 5%+",
        "on-scroll-down": "brightnessctl s 5%-"
    }
}
